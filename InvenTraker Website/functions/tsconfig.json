{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "lib",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "baseUrl": "..",
    "paths": {
      "@inventracker/shared": ["packages/shared/src/index.ts"],
      "@inventracker/shared/*": ["packages/shared/src/*"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
