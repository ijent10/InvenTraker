{
  "name": "@inventracker/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NEXT_TELEMETRY_DISABLED=1 NODE_ENV=development next dev -p 3000",
    "dev:clean": "rm -rf .next && NEXT_TELEMETRY_DISABLED=1 NEXT_DISABLE_WEBPACK_CACHE=1 NODE_ENV=development next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:e2e": "playwright test",
    "test": "vitest run"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.3",
    "@inventracker/shared": "1.0.0",
    "@inventracker/ui": "1.0.0",
    "@tanstack/react-query": "^5.66.8",
    "firebase": "^11.1.0",
    "lucide-react": "^0.484.0",
    "next": "^14.2.5",
    "pdf-parse": "^1.1.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.54.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.23",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.5",
    "playwright": "^1.51.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
